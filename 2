import csv

# Candidate Elimination Function
def candidate_elimination(concepts, targets):
    specific_h = concepts[0].copy()
    general_h = [["?" for i in range(len(specific_h))] 
                 for j in range(len(specific_h))]

    for i, h in enumerate(concepts):
        if targets[i] == "Yes":
            for x in range(len(specific_h)):
                if h[x] != specific_h[x]:
                    specific_h[x] = "?"
        else:
            for x in range(len(specific_h)):
                if h[x] != specific_h[x]:
                    general_h[x][x] = specific_h[x]
                else:
                    general_h[x][x] = "?"
    return specific_h, general_h


# Step 3: Read CSV file
concepts = []
targets = []

with open("data.csv", "r") as file:
    reader = csv.reader(file)
    next(reader)  # skip header

    for row in reader:
        concepts.append(row[:-1])  # all columns except last
        targets.append(row[-1])    # last column (Yes/No)

# Step 4: Call the function
specific_h, general_h = candidate_elimination(concepts, targets)

print("Final Specific Hypothesis:", specific_h)
print("Final General Hypothesis:", general_h)
